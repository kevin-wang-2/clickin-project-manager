# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# self-hosted fonts (large binaries, deployed via rsync)
/public/fonts/
.r2-config

# AI agent instruction files (not intended for human readers)
AGENTS.md
agent_bot.md

# Local deployment config (contains sensitive server/credential info)
docs/DEPLOY_LOCAL.md
Trace-*.json
